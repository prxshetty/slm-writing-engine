# LM Studio / Local LLM endpoint
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=

# Reasoning model toggle — set to true if using a thinking model
# (e.g. Gemma Thinking, DeepSeek R1). Prepends a thinking preamble
# to every system prompt and captures reasoning_content from responses.
REASONING_MODEL=false

# Disable all token limits — lets the model run without any max_tokens
# cap. Ignores TOKENS_* env vars and style output_size.
# Useful for powerful models or when you want the model to decide
# when to stop generating. Set to true to unlock.
DISABLE_TOKEN_LIMITS=false

# Token limits — floor per beat/response, not a cap.
# Style output_size (concise/balanced/expansive) overrides these upward.
# Increase if using a more powerful model.
TOKENS_BLUEPRINT=2000
TOKENS_SCENE=600
TOKENS_DIALOGUE=800
TOKENS_NARRATION=800
TOKENS_DECOMPOSER=600
TOKENS_WRITER=500
TOKENS_TRANSITION=400
